generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String?
  phone        String?
  role         Role         @default(JOB_SEEKER)
  isActive    Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
  jobs         Job[]
  auditLogsTarget AuditLog[] @relation("TargetUser")

  @@map("users")
}

model AuditLog {
  id          String   @id @default(cuid())
  adminEmail String
  action     String
  targetUserId String?
  targetUser User?   @relation("TargetUser", fields: [targetUserId], references: [id])
  details    String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model EmployerRequest {
  id          String        @id @default(cuid())
  companyName String
  email       String
  phone       String
  password    String
  status      RequestStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("employer_requests")
}

model Job {
  id           String        @id @default(cuid())
  title        String
  description  String
  requirements String?
  benefits     String?
  salary       String?
  location     String
  destination  String
  categoryId   String
  employerId   String
  status       JobStatus    @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  category     Category      @relation(fields: [categoryId], references: [id])
  employer     User          @relation(fields: [employerId], references: [id])
  applications Application[]

  @@map("jobs")
}

model Category {
  id   String @id @default(cuid())
  name String @unique
  icon String?
  jobs Job[]

  @@map("categories")
}

model Application {
  id          String            @id @default(cuid())
  userId      String
  jobId       String
  status      ApplicationStatus @default(PENDING)
  coverLetter String?
  resumeUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User @relation(fields: [userId], references: [id])
  job         Job  @relation(fields: [jobId], references: [id])

  @@unique([userId, jobId])
  @@map("applications")
}

enum Role {
  JOB_SEEKER
  EMPLOYER
  ADMIN
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum JobStatus {
  ACTIVE
  CLOSED
  DRAFT
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  ACCEPTED
  REJECTED
}
